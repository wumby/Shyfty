APP_ENV=development
PORT=8001
FRONTEND_ORIGIN=http://localhost:5175
API_PUBLIC_URL=http://localhost:8001
TRUST_PROXY_HEADERS=false
ALLOWED_HOSTS=localhost,127.0.0.1

# Local dev can use SQLite; production must use PostgreSQL.
DATABASE_URL=sqlite:////absolute/path/to/shyfty.db
# DATABASE_URL=postgresql+psycopg://shyfty:replace-me@localhost:5432/shyfty

# Comma-separated list for cross-origin requests.
CORS_ORIGINS=http://127.0.0.1:5175,http://localhost:5175

SESSION_SECRET=replace-me-session-secret
JWT_SECRET=replace-me-jwt-secret

AUTH_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
CSRF_COOKIE_SAMESITE=lax

# Email / SMTP for password reset emails.
# Leave blank to skip sending — the reset link will be logged to console instead (useful for dev).
# Works with any SMTP provider: Resend, SendGrid, Postmark, Mailgun, Gmail, etc.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=your-api-key-here
SMTP_FROM_ADDRESS=noreply@yourdomain.com
SMTP_FROM_NAME=Shyfty

# Keep background ingest off by default in production API servers.
SYNC_SCHEDULER_ENABLED=true
SYNC_RUN_ON_STARTUP=false
SYNC_LOOKBACK_DAYS=1
SYNC_LOOKAHEAD_DAYS=1
STAT_CORRECTION_LOOKBACK_HOURS=48
ENABLE_NBA_SYNC=true
ENABLE_NFL_SYNC=false
